# Database connection (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5433/mentaro
DB_USERNAME=mentaro
DB_PASSWORD=mentaro

# Comma-separated list of origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Port the server listens on (Railway sets this automatically in production)
PORT=8080

# Firebase service account JSON (Project Settings > Service accounts > Generate
# new private key), base64-encoded onto a single line:
#   base64 -w0 service-account.json   (Linux/macOS)
#   certutil -encode service-account.json tmp.b64  (Windows, then strip header/footer lines)
FIREBASE_SERVICE_ACCOUNT_BASE64=

# DeepSeek API (platform.deepseek.com > API keys)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODELO_PASADA_A=deepseek-v4-flash
DEEPSEEK_MODELO_PASADA_B=deepseek-v4-flash
DEEPSEEK_MODELO_PASADA_B_ESCALADO=deepseek-v4-pro
# Formato ISO-8601 duration. La Pasada B (thinking + reasoning_effort alto
# sobre un lote de unidades) puede tardar varios minutos - un timeout de
# lectura corto corta la conexion a mitad de una respuesta valida.
DEEPSEEK_TIMEOUT_CONEXION=PT10S
DEEPSEEK_TIMEOUT_LECTURA=PT5M

# Anthropic API (console.anthropic.com > API keys) - usada solo para
# describir imagenes embebidas en documentos (DeepSeek no acepta imagenes).
ANTHROPIC_API_KEY=
